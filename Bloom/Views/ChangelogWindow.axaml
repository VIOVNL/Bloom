<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Bloom.ViewModels"
        x:Class="Bloom.Views.ChangelogWindow"
        x:DataType="vm:ChangelogViewModel"
        Title="What's New"
        Icon="/Assets/bloom.ico"
        Width="380" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.heading">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.versionHeader">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.versionDate">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
        </Style>

        <!-- Tag badges -->
        <Style Selector="Border.tagNew">
            <Setter Property="Background" Value="#1A51CF66"/>
            <Setter Property="BorderBrush" Value="#3351CF66"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
        </Style>
        <Style Selector="Border.tagNew TextBlock">
            <Setter Property="Foreground" Value="#51CF66"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="Border.tagImproved">
            <Setter Property="Background" Value="#1A339AF0"/>
            <Setter Property="BorderBrush" Value="#33339AF0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
        </Style>
        <Style Selector="Border.tagImproved TextBlock">
            <Setter Property="Foreground" Value="#339AF0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="Border.tagFixed">
            <Setter Property="Background" Value="#1AFF6B6B"/>
            <Setter Property="BorderBrush" Value="#33FF6B6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
        </Style>
        <Style Selector="Border.tagFixed TextBlock">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="Border.separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Styles>

    <!-- Main shell -->
    <Border CornerRadius="14"
            ClipToBounds="True"
            BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource DialogBorderStart}" Offset="0"/>
                <GradientStop Color="{DynamicResource DialogBorderEnd}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource DialogBgStart}" Offset="0"/>
                <GradientStop Color="{DynamicResource DialogBgEnd}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <DockPanel Margin="20,16,20,18">

            <!-- Header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock Classes="heading" Text="What's New"/>
                <Border x:Name="CloseBtn"
                        Grid.Column="1"
                        Width="26" Height="26" CornerRadius="13"
                        Background="{DynamicResource CloseBtnBg}" Cursor="Hand"
                        Focusable="True"
                        VerticalAlignment="Top">
                    <Viewbox Width="10" Height="10">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource CloseIconStroke}" StrokeThickness="2.5"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Data="M18 6 6 18 M6 6l12 12"/>
                        </Canvas>
                    </Viewbox>
                </Border>
            </Grid>

            <!-- Scrollable changelog content -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Versions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChangelogVersionGroup">
                            <StackPanel Margin="0,4,0,12">
                                <!-- Version + date -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                                    <TextBlock Classes="versionHeader" Text="{Binding Version}"/>
                                    <TextBlock Classes="versionDate" Text="{Binding Date}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Entries -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChangelogDisplayItem">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
                                                <Border Classes.tagNew="{Binding Type, Converter={x:Static vm:ChangelogConverters.IsFeature}}"
                                                        Classes.tagImproved="{Binding Type, Converter={x:Static vm:ChangelogConverters.IsImprovement}}"
                                                        Classes.tagFixed="{Binding Type, Converter={x:Static vm:ChangelogConverters.IsFix}}"
                                                        VerticalAlignment="Top"
                                                        MinWidth="62">
                                                    <TextBlock Text="{Binding Prefix}" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Top"
                                                           MaxWidth="260"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
