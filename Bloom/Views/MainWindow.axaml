<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Bloom.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
        x:Class="Bloom.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Bloom"
        Icon="/Assets/bloom.ico"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        CanResize="False"
        ShowInTaskbar="False"
        Width="60" Height="60"
        WindowStartupLocation="Manual"
        DragDrop.AllowDrop="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border#BloomButton">
            <Setter Property="Opacity" Value="0.9"/>
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="30%,0%" EndPoint="70%,100%">
                    <GradientStop Color="{DynamicResource BloomButtonBgStart}" Offset="0"/>
                    <GradientStop Color="{DynamicResource BloomButtonBgEnd}" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Border#BloomButton:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Flower petals: grey by default -->
        <Style Selector="Path.petal">
            <Setter Property="Fill" Value="#A0A0A0"/>
        </Style>
        <Style Selector="Path#FlowerCenter">
            <Setter Property="Fill" Value="#C8C8C8"/>
        </Style>

        <!-- Hover: each petal gets its own color -->
        <Style Selector="Border#BloomButton:pointerover Path#Petal1">
            <Setter Property="Fill" Value="#FF6B6B"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal2">
            <Setter Property="Fill" Value="#FFA94D"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal3">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal4">
            <Setter Property="Fill" Value="#51CF66"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal5">
            <Setter Property="Fill" Value="#339AF0"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal6">
            <Setter Property="Fill" Value="#5C7CFA"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal7">
            <Setter Property="Fill" Value="#CC5DE8"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#Petal8">
            <Setter Property="Fill" Value="#F06595"/>
        </Style>
        <Style Selector="Border#BloomButton:pointerover Path#FlowerCenter">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>

        <!-- Open state: fully opaque background + same colors -->
        <Style Selector="Border#BloomButton.open">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="30%,0%" EndPoint="70%,100%">
                    <GradientStop Color="{DynamicResource BloomButtonBgStartSolid}" Offset="0"/>
                    <GradientStop Color="{DynamicResource BloomButtonBgEndSolid}" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal1">
            <Setter Property="Fill" Value="#FF6B6B"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal2">
            <Setter Property="Fill" Value="#FFA94D"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal3">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal4">
            <Setter Property="Fill" Value="#51CF66"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal5">
            <Setter Property="Fill" Value="#339AF0"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal6">
            <Setter Property="Fill" Value="#5C7CFA"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal7">
            <Setter Property="Fill" Value="#CC5DE8"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#Petal8">
            <Setter Property="Fill" Value="#F06595"/>
        </Style>
        <Style Selector="Border#BloomButton.open Path#FlowerCenter">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>

        <!-- Drag-hover: same colors as pointer hover -->
        <Style Selector="Border#BloomButton.draghover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal1">
            <Setter Property="Fill" Value="#FF6B6B"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal2">
            <Setter Property="Fill" Value="#FFA94D"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal3">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal4">
            <Setter Property="Fill" Value="#51CF66"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal5">
            <Setter Property="Fill" Value="#339AF0"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal6">
            <Setter Property="Fill" Value="#5C7CFA"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal7">
            <Setter Property="Fill" Value="#CC5DE8"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#Petal8">
            <Setter Property="Fill" Value="#F06595"/>
        </Style>
        <Style Selector="Border#BloomButton.draghover Path#FlowerCenter">
            <Setter Property="Fill" Value="#FFD43B"/>
        </Style>
    </Window.Styles>

    <Border x:Name="BloomButton"
            Width="52" Height="52"
            CornerRadius="26"
            BorderThickness="1"
            Cursor="Hand"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource BloomButtonBorderStart}" Offset="0"/>
                <GradientStop Color="{DynamicResource BloomButtonBorderEnd}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
            </Transitions>
        </Border.Transitions>

        <Viewbox x:Name="BloomIcon" Width="36" Height="36">
            <Canvas Width="24" Height="24">
                <!-- 8-petal flower with round cubic bezier petals -->
                <Path x:Name="Petal1" Classes="petal"
                      Data="M12,12 C8.5,10 7.8,6.5 12,4.5 C16.2,6.5 15.5,10 12,12 Z"/>
                <Path x:Name="Petal2" Classes="petal"
                      Data="M12,12 C10.9,8.1 12.9,5.1 17.3,6.7 C18.9,11.1 15.9,13.1 12,12 Z"/>
                <Path x:Name="Petal3" Classes="petal"
                      Data="M12,12 C14,8.5 17.5,7.8 19.5,12 C17.5,16.2 14,15.5 12,12 Z"/>
                <Path x:Name="Petal4" Classes="petal"
                      Data="M12,12 C15.9,10.9 18.9,12.9 17.3,17.3 C12.9,18.9 10.9,15.9 12,12 Z"/>
                <Path x:Name="Petal5" Classes="petal"
                      Data="M12,12 C15.5,14 16.2,17.5 12,19.5 C7.8,17.5 8.5,14 12,12 Z"/>
                <Path x:Name="Petal6" Classes="petal"
                      Data="M12,12 C13.1,15.9 11.1,18.9 6.7,17.3 C5.1,12.9 8.1,10.9 12,12 Z"/>
                <Path x:Name="Petal7" Classes="petal"
                      Data="M12,12 C10,15.5 6.5,16.2 4.5,12 C6.5,7.8 10,8.5 12,12 Z"/>
                <Path x:Name="Petal8" Classes="petal"
                      Data="M12,12 C8.1,13.1 5.1,11.1 6.7,6.7 C11.1,5.1 13.1,8.1 12,12 Z"/>
                <!-- Center -->
                <Path x:Name="FlowerCenter">
                    <Path.Data>
                        <EllipseGeometry Center="12,12" RadiusX="2.5" RadiusY="2.5"/>
                    </Path.Data>
                </Path>
            </Canvas>
        </Viewbox>
    </Border>

</Window>
